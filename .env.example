# Public site
NEXT_PUBLIC_SITE_URL=https://YOUR_DOMAIN.com
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/roararenaindia/
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/RoarArena
NEXT_PUBLIC_X_URL=https://x.com/RoarArenaIndia
NEXT_PUBLIC_WHATSAPP_CHANNEL_URL=https://whatsapp.com/channel/0029Vb8bGxc7oQhX9QvoPG1R
NEXT_PUBLIC_CONTACT_EMAIL=roararenaindia@gmail.com

# Optional Google visibility/analytics. These are public IDs, not secrets.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Required for deployed admin/cron protection
# Put real secret values in .env.local locally or Vercel Environment Variables.
CRON_SECRET=replace_with_a_long_random_secret

# Required for automatic football fixtures/results
# Free World Cup provider. Put the real token in .env.local or Vercel, not in this example file.
MATCH_DATA_PROVIDER=football-data
FOOTBALL_DATA_TOKEN=replace_with_your_football_data_org_token
FOOTBALL_DATA_COMPETITION=WC
FOOTBALL_DATA_SEASON=2026
MATCH_SYNC_PAST_DAYS=7
MATCH_SYNC_FUTURE_DAYS=7
MATCH_SELF_HEAL_ENABLED=true
MATCH_SELF_HEAL_STALE_MINUTES=20

# Optional paid/API-Sports fallback provider
API_FOOTBALL_KEY=replace_with_your_api_football_key
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# Optional tennis fixtures provider.
# ESPN is the keyless default. API-Tennis remains available as a private-key fallback.
TENNIS_DATA_PROVIDER=espn
TENNIS_ESPN_EVENT_ID=188-2026
TENNIS_ESPN_LEAGUE=atp
TENNIS_API_KEY=
TENNIS_TOURNAMENT_NAME_FILTER=
TENNIS_TOURNAMENT_KEY=
TENNIS_TIMEZONE=UTC
TENNIS_SYNC_PAST_DAYS=2
TENNIS_SYNC_FUTURE_DAYS=10

# Required only when you want database-backed live match updates
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional social automation. Add real values in .env.local or Vercel only.
INSTAGRAM_API_MODE=instagram_login
INSTAGRAM_GRAPH_API_VERSION=v20.0
INSTAGRAM_USER_ID=your_numeric_instagram_user_id
INSTAGRAM_ACCESS_TOKEN=your_long_lived_instagram_access_token
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=replace_with_a_long_random_webhook_verify_token
META_APP_SECRET=replace_with_your_meta_app_secret
INSTAGRAM_SYNC_LIMIT=18
INSTAGRAM_STORAGE_BUCKET=roar-instagram

X_USERNAME=RoarArenaIndia
X_USER_ID=
X_BEARER_TOKEN=
X_SYNC_LIMIT=10
